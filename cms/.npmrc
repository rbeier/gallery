# @amicaldo/strapi-google-maps declares node <=22 and needs peer-dep leniency,
# so strict engine checking is disabled here to keep `npm install` working on
# the pinned Node 24. The .nvmrc + package.json engines still document Node 24,
# and better-sqlite3's native ABI check fails loudly if the wrong Node is used.
legacy-peer-deps=true
engine-strict=false
